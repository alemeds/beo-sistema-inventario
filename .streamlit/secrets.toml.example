# Copiá este archivo como secrets.toml y completá con tus valores reales.
# NUNCA subas secrets.toml al repositorio.

[database]
host = "tu-host.neon.tech"
port = "5432"
database = "tu-database"
username = "tu-usuario"
password = "tu-password"

[users]
admin_user = "gran_arquitecto"
admin_password = "cambiar-esta-password"
admin_name = "Gran Arquitecto"
admin_role = "admin"
hospitalario_user = "hospitalario"
hospitalario_password = "cambiar-esta-password"
hospitalario_name = "Hospitalario"
hospitalario_role = "hospitalario"
maestro_user = "maestro"
maestro_password = "cambiar-esta-password"
maestro_name = "Maestro"
maestro_role = "maestro"
